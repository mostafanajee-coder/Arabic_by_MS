# Arabic by M.S - environment variable template
# Copy this file to ".env" and fill in real values for the variables
# you actually want to override. Phase 6 keeps Gemini translation and adds
# optional SubDL + SubSource subtitle search/import. Do not put real keys in
# this file if you plan to share or commit it.

# --- Addon identity -----------------------------------------------------
ADDON_ID=community.arabic.by.ms
ADDON_NAME=Arabic by M.S
ADDON_VERSION=0.6.0
ADDON_DESCRIPTION=Arabic subtitles for Stremio. Phase 6 (SubDL + SubSource search/import + Gemini translation).

# --- Server -------------------------------------------------------------
HOST=0.0.0.0
PORT=8787
# Public URL Stremio can reach. Use http://127.0.0.1:8787 for local use.
PUBLIC_BASE_URL=http://127.0.0.1:8787

# --- Gemini (Phase 6 still uses this) -----------------------------------
# Required to use POST /companion/translate/{record_id}.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash. Other options: gemini-2.5-pro, gemini-1.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# --- SubDL (Phase 6) ----------------------------------------------------
# Required to use GET /companion/search-subdl and POST /companion/import-subdl.
SUBDL_API_KEY=
SUBDL_BASE_URL=https://api.subdl.com/api/v1

# --- SubSource (Phase 6) ------------------------------------------------
# Required to use GET /companion/search-subsource and POST /companion/import-subsource.
SUBSOURCE_API_KEY=
SUBSOURCE_BASE_URL=https://api.subsource.net

# --- Future phases (NOT used yet) ---------------------------------------
# NVIDIA_API_KEY=
# OPENSUBTITLES_API_KEY=
# OPENSUBTITLES_USER_AGENT=
