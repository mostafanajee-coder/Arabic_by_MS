# Arabic by M.S - environment variable template
# Copy this file to ".env" and fill in real values for the variables
# you actually want to override. Phase 26 keeps the Phase 25 cache
# integrity verification, Phase 24 local-first import history, Phase 22
# quarantine memory, Phase 21 fallback, Phase 20 subtitle quality gate,
# Phase 19 match intelligence, Phase 18 reliability, and Phase 17
# OpenSubtitles workflow, and adds safe cache maintenance scanning.
# Do not put real keys in this file if you plan to share or commit it.

# --- Addon identity -----------------------------------------------------
ADDON_ID=community.arabic.by.ms
ADDON_NAME=Arabic by M.S
ADDON_VERSION=0.26.0
ADDON_DESCRIPTION=Arabic subtitles for Stremio. Phase 26 (safe cache maintenance scanning and orphan cleanup planning, cache integrity verification before cached subtitle reuse, local-first subtitle reuse, provider subtitle import history, duplicate-import prevention, provider candidate quarantine memory, quality-aware import-best fallback, subtitle quality inspection, safe auto-rejection hints, subtitle match intelligence, transparent best-choice explanations, provider reliability hardening, transparent provider diagnostics, safe retries, OpenSubtitles provider support, safe batch episode prepare queue, usage guardrails, duplicate-cost prevention, one-click prepare workflow, optional auto-prepare, subtitle preview, timing offset adjustments, preferred record management, honest status subtitles, background translation jobs).

# --- Server -------------------------------------------------------------
HOST=0.0.0.0
PORT=8787
# Public URL Stremio can reach. Use http://127.0.0.1:8787 for local use.
PUBLIC_BASE_URL=http://127.0.0.1:8787
# Optional. If true, /subtitles may start background prepare automatically
# when no exact Arabic subtitle is ready yet. This can consume provider and
# Gemini quota, so leave it false unless you explicitly want that behavior.
AUTO_PREPARE_ON_SUBTITLES_REQUEST=false
# Optional. If true, auto-prepare may keep running even after local daily
# limits are reached. The safe default is false.
ALLOW_AUTO_PREPARE_WHEN_LIMITED=false

# --- Phase 26 local safety limits ---------------------------------------
# Safe defaults for personal use. These protect free-tier Gemini/provider
# quotas from repeated or duplicate expensive operations.
MAX_DAILY_GEMINI_TRANSLATIONS=20
MAX_DAILY_PROVIDER_SEARCHES=100
MAX_DAILY_PREPARE_REQUESTS=50
MAX_BATCH_PREPARE_ITEMS=10

# --- Gemini (Phase 8 still uses this) -----------------------------------
# Required to use POST /companion/translate/{record_id} or auto-translate via
# POST /companion/import-best. Translation now runs in validated chunks and
# exposes progress via GET /companion/translation-status/{record_id}.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash. Other options: gemini-2.5-pro, gemini-1.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# --- SubDL (Phase 8) ----------------------------------------------------
# Required to use GET /companion/search-subdl, GET /companion/search-all,
# POST /companion/import-subdl, and possibly POST /companion/import-best.
SUBDL_API_KEY=
SUBDL_BASE_URL=https://api.subdl.com/api/v1

# --- SubSource (Phase 8) ------------------------------------------------
# Required to use GET /companion/search-subsource, GET /companion/search-all,
# POST /companion/import-subsource, and possibly POST /companion/import-best.
SUBSOURCE_API_KEY=
SUBSOURCE_BASE_URL=https://api.subsource.net

# --- OpenSubtitles (Phase 26) -------------------------------------------
# Required to use GET /companion/search-opensubtitles, GET /companion/search-all,
# POST /companion/import-opensubtitles, and possibly POST /companion/import-best.
OPENSUBTITLES_API_KEY=
# Required by the OpenSubtitles API. Use a stable app identifier string.
OPENSUBTITLES_USER_AGENT=
OPENSUBTITLES_BASE_URL=https://api.opensubtitles.com/api/v1

# --- Future phases (NOT used yet) ---------------------------------------
# NVIDIA_API_KEY=
