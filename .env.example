# Arabic by M.S - environment variable template
# Copy this file to ".env" and fill in real values for the variables
# you actually want to override. Nothing below is required for Phase 1 / 2;
# Phase 3 needs GEMINI_API_KEY (and optionally GEMINI_MODEL) when you click
# Translate on the companion page.

# --- Addon identity -----------------------------------------------------
ADDON_ID=community.arabic.by.ms
ADDON_NAME=Arabic by M.S
ADDON_VERSION=0.3.0
ADDON_DESCRIPTION=Arabic subtitles for Stremio. Phase 3 (Gemini translation).

# --- Server -------------------------------------------------------------
HOST=0.0.0.0
PORT=8787
# Public URL Stremio can reach. Use http://127.0.0.1:8787 for local use.
PUBLIC_BASE_URL=http://127.0.0.1:8787

# --- Gemini (Phase 3) ---------------------------------------------------
# Required to use POST /companion/translate/{record_id}.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash. Other options: gemini-2.5-pro, gemini-1.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# --- Future phases (NOT used yet) ---------------------------------------
# NVIDIA_API_KEY=
# SUBDL_API_KEY=
# SUBSOURCE_API_KEY=
# OPENSUBTITLES_API_KEY=
# OPENSUBTITLES_USER_AGENT=
